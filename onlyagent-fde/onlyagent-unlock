#!/bin/sh
# onlyagent-unlock — boot-time LUKS unlock for the OnlyAgent data partition.
# First boot provisions LUKS2 with a SINGLE keyslot (the OnlyKey KEK); every later
# boot opens it. The KEK travels only through a pipe. Recovery is "restore your
# OnlyKey backup" — no passphrase keyslot, by design (see the provision step).
#
# Depends: cryptsetup, i2c-tools (optional, for presence check), python3 +
# python-onlykey (I2C transport), okfde-client on PATH.
set -eu

DEV="${OKFDE_DEV:-/dev/mmcblk0p3}"    # data partition
NAME="${OKFDE_NAME:-okdata}"
MOUNT="${OKFDE_MOUNT:-/data}"
BUS="${OKFDE_BUS:-1}"
ADDR="${OKFDE_ADDR:-0x2c}"

log() { echo "onlyagent-unlock: $*" >&2; }

led_slow_blink() { [ -x /usr/sbin/okled ] && okled slow-blink || true; }
led_ok()         { [ -x /usr/sbin/okled ] && okled solid     || true; }
led_error()      { [ -x /usr/sbin/okled ] && okled error     || true; }

if [ -e "/dev/mapper/${NAME}" ]; then
    log "already unlocked"
    exit 0
fi

led_slow_blink
log "waiting for OnlyKey PIN entry on the keypad..."

# Derive the KEK. --wait-pin polls until the user unlocks the key (up to 2 min).
# okfde-client prints 32 raw bytes to stdout; capture without touching disk.
if ! KEKHEX="$(okfde-client --bus "$BUS" --addr "$ADDR" --wait-pin --hex)"; then
    led_error
    log "KEK derivation failed"
    exit 1
fi
[ -n "$KEKHEX" ] || { led_error; log "empty KEK"; exit 1; }

# Helper: feed the raw KEK to a cryptsetup command via stdin pipe.
kek_pipe() { printf '%s' "$KEKHEX" | xxd -r -p; }

if ! cryptsetup isLuks "$DEV" 2>/dev/null; then
    # ---- first use: provision ----
    log "no LUKS header on $DEV — provisioning (first boot)"
    # ONE keyslot, the OnlyKey KEK. Recovery is "restore your OnlyKey backup":
    # the KEK is derived from the web-derivation key (slot 128), which the backup
    # includes (okcore.cpp BACKUP loops slots 101..132), so a restored OnlyKey
    # re-derives the same seed -> same decapsulation of the stored ct -> same KEK.
    #
    # Deliberately NO recovery-passphrase keyslot: it would be a second, weaker
    # path to the data (paper vs. hardware-gated) and would break the guarantee
    # that the disk cannot be opened without the OnlyKey.
    kek_pipe | cryptsetup luksFormat --type luks2 --key-file=- "$DEV"
    kek_pipe | cryptsetup open --key-file=- "$DEV" "$NAME"
    mkfs.ext4 -q "/dev/mapper/${NAME}"
    log "provisioned (single keyslot: OnlyKey KEK)"
else
    # ---- every later boot ----
    kek_pipe | cryptsetup open --key-file=- "$DEV" "$NAME"
    log "unlocked"
fi

unset KEKHEX 2>/dev/null || true

mkdir -p "$MOUNT"
mount "/dev/mapper/${NAME}" "$MOUNT"
led_ok
log "mounted at $MOUNT"
